/* app.wxss - 全局Sigma风格 */

page {
  background: #0a0a0b;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* 全局毛玻璃效果 */
.blur-bg {
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(40px);
}

/* TabBar样式覆盖 */
page {
  min-height: 100vh;
}

/* button样式 */
button {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
}

button::after {
  border: none;
}

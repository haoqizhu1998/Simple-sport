{
  "collectionName": "medals",
  "description": "运动勋章表",
  "schema": {
    "bsonType": "object",
    "required": ["user_id", "medal_type", "medal_name", "earned_at"],
    "properties": {
      "_id": {
        "bsonType": "string",
        "description": "记录ID"
      },
      "user_id": {
        "bsonType": "string",
        "description": "用户ID"
      },
      "medal_type": {
        "bsonType": "string",
        "description": "勋章类型标识"
      },
      "medal_name": {
        "bsonType": "string",
        "description": "勋章名称"
      },
      "medal_icon": {
        "bsonType": "string",
        "description": "勋章图标URL"
      },
      "condition": {
        "bsonType": "string",
        "description": "获得条件说明"
      },
      "earned_at": {
        "bsonType": "date",
        "description": "获得时间"
      }
    }
  },
  "indexes": [

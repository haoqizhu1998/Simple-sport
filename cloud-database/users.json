{
  "collectionName": "users",
  "description": "用户信息表",
  "schema": {
    "bsonType": "object",
    "required": ["_id", "created_at", "updated_at"],
    "properties": {
      "_id": {
        "bsonType": "string",
        "description": "用户ID (微信openid)"
      },
      "nickname": {
        "bsonType": "string",
        "description": "用户昵称"
      },
      "avatar_url": {
        "bsonType": "string",
        "description": "头像URL"
      },
      "phone": {
        "bsonType": "string",
        "description": "手机号(脱敏存储)"
      },
      "gender": {
        "enum": ["male", "female", "other", ""],
        "description": "性别"
      },
      "birthday": {
        "bsonType": "string",
        "description": "生日日期"
      },
      "region": {
        "bsonType": "string",
        "description": "地区"
      },
      "level": {
        "bsonType": "int",
        "description": "运动等级",
        "default": 1
      },
      "exp_points": {
        "bsonType": "int",
        "description": "经验值",
        "default": 0
      },
      "total_trainings": {
        "bsonType": "int",
        "description": "训练总次数",
        "default": 0
      },
      "total_distance": {
        "bsonType": "double",
        "description": "总公里数",
        "default": 0
      },
      "streak_days": {
        "bsonType": "int",
        "description": "连续运动天数",
        "default": 0
      },
      "created_at": {
        "bsonType": "date",
        "description": "创建时间"
      },
      "updated_at": {
        "bsonType": "date",
        "description": "更新时间"
      }
    }
  },
  "indexes": [
    {
      "indexName": "_id",
      "indexType": "unique"
    }
  ],
  "data": []
}

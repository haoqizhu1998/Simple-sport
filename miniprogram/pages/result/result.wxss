/* pages/result/result.wxss */
.result-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 160rpx;
}

/* 头部卡片 */
.header-card {
  background: linear-gradient(135deg, #1A1A2E 0%, #16213E 100%);
  padding: 30rpx;
  border-radius: 0 0 40rpx 40rpx;
  margin-bottom: 30rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.type-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(255, 255, 255, 0.15);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

.type-icon {
  font-size: 28rpx;
}

.type-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.date-info {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 评分区域 */
.score-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.score-ring {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  margin-bottom: 20rpx;
}

.score-ring-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 20rpx solid rgba(255, 255, 255, 0.1);
}

.score-ring-progress {
  position: absolute;
  top: -20rpx;
  left: -20rpx;
  width: calc(100% + 40rpx);
  height: calc(100% + 40rpx);
  border-radius: 50%;
  border: 20rpx solid transparent;
  border-top-color: var(--color, #00FF88);
  transform: rotate(-90deg);
  clip-path: polygon(50% 50%, 50% 0%, 100% 0%, 100% 100%, 0% 100%, 0% 0%, 50% 0%);
}

.score-ring-progress::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 50%;
  border: 20rpx solid transparent;
  border-top-color: var(--color, #00FF88);
  transform: rotate(calc(var(--progress) * 3.6deg));
}

.score-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.score-value {
  font-size: 80rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

.score-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.score-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}

.quality-tag {
  padding: 8rpx 30rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  background: rgba(0, 255, 136, 0.3);
}

.quality-tag.good {
  background: rgba(0, 217, 255, 0.3);
}

.quality-tag.normal {
  background: rgba(255, 184, 0, 0.3);
}

.quality-tag.poor {
  background: rgba(255, 107, 107, 0.3);
}

.quality-desc {
  text-align: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  padding: 0 40rpx;
  line-height: 1.6;
}

/* 通用卡片样式 */
.data-card, .ability-card, .suggestion-card {
  margin: 0 30rpx 30rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 数据网格 */
.data-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.data-item {
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
}

.data-icon {
  font-size: 32rpx;
  margin-bottom: 10rpx;
}

.data-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.2;
}

.data-unit {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 能力影响列表 */
.ability-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.ability-item {
  display: flex;
  align-items: center;
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 24rpx;
}

.ability-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.ability-info {
  flex: 1;
}

.ability-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.ability-change {
  font-size: 24rpx;
}

.ability-change.positive {
  color: #00FF88;
}

.ability-change.negative {
  color: #FF6B6B;
}

.ability-indicator {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.ability-indicator.up {
  background: rgba(0, 255, 136, 0.15);
  color: #00FF88;
}

.ability-indicator.down {
  background: rgba(255, 107, 107, 0.15);
  color: #FF6B6B;
}

/* 建议列表 */
.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
}

.suggestion-item.action {
  background: linear-gradient(135deg, rgba(0, 217, 255, 0.1) 0%, rgba(0, 180, 216, 0.1) 100%);
  border: 1rpx solid rgba(0, 217, 255, 0.2);
}

.suggestion-icon {
  font-size: 28rpx;
  margin-top: 2rpx;
}

.suggestion-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 分享区域 */
.share-section {
  padding: 30rpx;
  display: flex;
  justify-content: center;
}

.share-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(0, 217, 255, 0.1);
  border: 1rpx solid rgba(0, 217, 255, 0.3);
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  color: #00D9FF;
}

.share-icon {
  font-size: 28rpx;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-outline {
  flex: 1;
  height: 96rpx;
  background: #FFFFFF;
  color: #00D9FF;
  border: 2rpx solid #00D9FF;
  border-radius: 48rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-filled {
  flex: 2;
  height: 96rpx;
  background: linear-gradient(135deg, #00D9FF 0%, #00B4D8 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 217, 255, 0.3);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #F0F0F0;
  border-top-color: #00D9FF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* pages/history/history.wxss */
.history-page {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 统计概览 */
.stats-overview {
  position: relative;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.overview-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #1A1A2E 0%, #16213E 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.overview-content {
  position: relative;
  z-index: 1;
  padding: 40rpx 30rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 筛选区域 */
.filter-section {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.filter-tabs {
  display: flex;
  gap: 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 8rpx;
}

.filter-tab {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.filter-tab.active {
  background: linear-gradient(135deg, #00D9FF 0%, #00B4D8 100%);
  color: #FFFFFF;
  font-weight: 500;
}

/* 历史列表 */
.history-list {
  padding: 0 30rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 分数圆圈 */
.item-score {
  margin-right: 24rpx;
}

.score-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
}

.score-value {
  font-size: 28rpx;
  font-weight: 700;
}

/* 内容区域 */
.item-content {
  flex: 1;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.item-type {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.type-icon {
  font-size: 28rpx;
}

.type-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.item-date {
  font-size: 24rpx;
  color: #999;
}

.item-stats {
  display: flex;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.stat-tag {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.tag-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.tag-unit {
  font-size: 22rpx;
  color: #999;
}

.item-quality {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.quality-badge {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  background: #00FF88;
}

.quality-badge.good {
  background: #00D9FF;
}

.quality-badge.normal {
  background: #FFB800;
}

.quality-badge.poor {
  background: #FF6B6B;
}

.quality-desc {
  font-size: 22rpx;
  color: #999;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 操作按钮 */
.item-action {
  padding: 10rpx 15rpx;
  margin-left: 10rpx;
  opacity: 0.6;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #00D9FF 0%, #00B4D8 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 30rpx rgba(0, 217, 255, 0.3);
}

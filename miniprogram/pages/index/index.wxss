/* pages/index/index.wxss */
.index-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1A1A2E 0%, #16213E 50%, #F5F5F5 50%);
}

/* 顶部区域 */
.header {
  position: relative;
  height: 280rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #1A1A2E 0%, #16213E 100%);
}

.header-content {
  position: relative;
  z-index: 1;
  padding: 40rpx 30rpx;
}

.greeting {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}

.date {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 今日数据卡片 */
.today-card {
  margin: -140rpx 30rpx 30rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.today-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.today-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.today-subtitle {
  font-size: 24rpx;
  color: #999;
}

/* 统计区域 */
.stats-container {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx 0 30rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #00D9FF;
  line-height: 1.2;
}

.stat-unit {
  font-size: 24rpx;
  color: #999;
  margin-top: 5rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #EEEEEE;
}

/* 快速添加按钮 */
.quick-action {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #00D9FF 0%, #00B4D8 100%);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-top: 20rpx;
}

.action-icon {
  width: 48rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.action-icon image {
  width: 28rpx;
  height: 28rpx;
}

.action-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.action-arrow {
  font-size: 36rpx;
  color: #FFFFFF;
  opacity: 0.8;
}

/* 周数据卡片 */
.week-card {
  margin: 0 30rpx 30rpx;
}

.week-chart {
  padding: 20rpx 0;
}

.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 200rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-wrapper {
  width: 40rpx;
  height: 140rpx;
  background: #F0F0F0;
  border-radius: 20rpx 20rpx 0 0;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

.bar {
  width: 100%;
  background: linear-gradient(180deg, #00D9FF 0%, #00B4D8 100%);
  border-radius: 20rpx 20rpx 0 0;
  min-height: 8rpx;
  transition: height 0.3s ease;
}

.bar-value {
  font-size: 20rpx;
  color: #00D9FF;
  margin: 8rpx 0 5rpx;
}

.bar-label {
  font-size: 24rpx;
  color: #999;
}

/* 最近训练卡片 */
.recent-card {
  margin: 0 30rpx 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.more-btn {
  font-size: 26rpx;
  color: #00D9FF;
}

.training-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.training-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
}

.training-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.training-type {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.training-type.aerobic { color: #00D9FF; }
.training-type.interval { color: #FF6B6B; }
.training-type.recovery { color: #00FF88; }
.training-type.long { color: #9B59B6; }

.training-date {
  font-size: 24rpx;
  color: #999;
}

.training-stats {
  display: flex;
  gap: 30rpx;
}

.training-stats .stat {
  text-align: center;
}

.training-stats .value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-right: 4rpx;
}

.training-stats .unit {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  margin: 100rpx 30rpx;
  text-align: center;
  padding: 60rpx 40rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-state text {
  display: block;
  color: #666;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.empty-hint {
  color: #999 !important;
  font-size: 24rpx !important;
  margin-bottom: 30rpx !important;
}

.empty-state .btn-primary {
  margin-top: 20rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

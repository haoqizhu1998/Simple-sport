/* pages/review/review.wxss */
.review-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 140rpx;
}

/* 页面头部 */
.page-header {
  background: linear-gradient(135deg, #1A1A2E 0%, #16213E 100%);
  padding: 40rpx 30rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 表单容器 */
.form-container {
  padding: 30rpx;
}

.input-group {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.input-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.label-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 10rpx;
}

/* 输入框 */
.input-field {
  width: 100%;
  height: 88rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 34rpx;
  box-sizing: border-box;
}

/* 配速输入组 */
.pace-input-group {
  display: flex;
  align-items: center;
}

.pace-input {
  width: 140rpx;
  height: 88rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  text-align: center;
  font-size: 34rpx;
}

.pace-separator {
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #666;
}

/* RPE选择器 */
.rpe-selector {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.rpe-option {
  width: 60rpx;
  height: 60rpx;
  background: #F0F0F0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.rpe-option.active {
  background: linear-gradient(135deg, #00D9FF 0%, #00B4D8 100%);
  color: #FFFFFF;
  transform: scale(1.1);
}

.rpe-hints {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #999;
}

.hint-center {
  text-align: center;
}

/* 图片上传 */
.image-upload-area {
  padding: 10rpx 0;
}

.image-list {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.image-item.main {
  width: 300rpx;
  height: 300rpx;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 32rpx;
  line-height: 1;
}

.main-tag {
  position: absolute;
  bottom: 10rpx;
  left: 10rpx;
  background: #00D9FF;
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  background: #F8F9FA;
  border: 2rpx dashed #DDD;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.upload-icon {
  font-size: 60rpx;
  color: #CCC;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-secondary {
  flex: 1;
  height: 96rpx;
  background: #F5F5F5;
  color: #666;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  flex: 2;
  height: 96rpx;
  background: linear-gradient(135deg, #00D9FF 0%, #00B4D8 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 217, 255, 0.3);
}

.btn-primary.loading {
  opacity: 0.8;
}

.btn-content, .loading-content {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.btn-icon {
  font-size: 36rpx;
}

.loading-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

<!-- pages/user/user.wxml -->
<view class="user-page">
  <!-- ========== 未登录状态 ========== -->
  <view class="login-container" wx:if="{{!isLoggedIn}}">
    <view class="login-avatar">
      <view class="avatar-ring">
        <view class="avatar-inner">
          <text class="avatar-default">S</text>
        </view>
      </view>
    </view>
    <text class="login-hint">登录后可查看完整个人中心</text>
    <button 
      class="login-btn"
      open-type="getPhoneNumber"
      bindgetphonenumber="onGetPhoneNumber"
    >
      <text class="login-btn-icon">📱</text>
      <text>微信手机号授权登录</text>
    </button>
    <button class="guest-btn" bindtap="onGuestLogin">
      <text>先看看</text>
    </button>
  </view>

  <!-- ========== 已登录状态 ========== -->
  <view class="logged-container" wx:if="{{isLoggedIn}}">
    <!-- 顶部个人信息卡片 -->
    <view class="profile-card">
      <view class="profile-bg"></view>
      <view class="profile-content">
        <view class="avatar-section">
          <view class="avatar-ring">
            <view class="avatar-inner">
              <image 
                wx:if="{{userInfo.avatarUrl}}"
                class="avatar-img"
                src="{{userInfo.avatarUrl}}"
                mode="aspectFill"
              />
              <text wx:else class="avatar-text">{{userInfo.nickname ? userInfo.nickname[0] : 'S'}}</text>
            </view>
          </view>
          <view class="user-info">
            <text class="user-name">{{userInfo.nickname || '运动达人'}}</text>
            <view class="level-badge">
              <text class="level-icon">🏆</text>
              <text class="level-text">Lv.{{userInfo.level || 1}}</text>
              <text class="exp-text">{{userInfo.expPoints || 0}} EXP</text>
            </view>
          </view>
        </view>
        <view class="stats-row">
          <view class="stat-item">
            <text class="stat-value">{{userInfo.totalTrainings || 0}}</text>
            <text class="stat-label">训练次数</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <text class="stat-value">{{userInfo.totalDistance || 0}}</text>
            <text class="stat-label">总公里数</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <text class="stat-value">{{userInfo.streakDays || 0}}</text>
            <text class="stat-label">连续天数</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Tab菜单 -->
    <view class="tab-menu">
      <view 
        class="tab-item {{currentTab === 'profile' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="profile"
      >
        <text class="tab-icon">👤</text>
        <text class="tab-text">个人资料</text>
      </view>
      <view 
        class="tab-item {{currentTab === 'health' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="health"
      >
        <text class="tab-icon">❤️</text>
        <text class="tab-text">健康档案</text>
      </view>
      <view 
        class="tab-item {{currentTab === 'data' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="data"
      >
        <text class="tab-icon">📊</text>
        <text class="tab-text">数据导入</text>
      </view>
      <view 
        class="tab-item {{currentTab === 'medal' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="medal"
      >
        <text class="tab-icon">🏅</text>
        <text class="tab-text">运动勋章</text>
      </view>
    </view>

    <!-- ========== 个人资料Tab ========== -->
    <view class="tab-content" wx:if="{{currentTab === 'profile'}}">
      <view class="section-card">
        <view class="card-header">
          <text class="card-title">基本信息</text>
          <text class="edit-btn" bindtap="editProfile">编辑</text>
        </view>
        <view class="info-list">
          <view class="info-item">
            <text class="info-label">昵称</text>
            <text class="info-value">{{userInfo.nickname || '未设置'}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">性别</text>
            <text class="info-value">{{getGenderName(userInfo.gender)}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">生日</text>
            <text class="info-value">{{userInfo.birthday || '未设置'}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">地区</text>
            <text class="info-value">{{userInfo.region || '未设置'}}</text>
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="card-header">
          <text class="card-title">联系方式</text>
        </view>
        <view class="info-list">
          <view class="info-item">
            <text class="info-label">手机号</text>
            <text class="info-value">{{userInfo.phone || '未绑定'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ========== 健康档案Tab ========== -->
    <view class="tab-content" wx:if="{{currentTab === 'health'}}">
      <view class="section-card">
        <view class="card-header">
          <text class="card-title">身体信息</text>
          <text class="edit-btn" bindtap="editHealthProfile">编辑</text>
        </view>
        <view class="info-list">
          <view class="info-item">
            <text class="info-label">年龄</text>
            <text class="info-value">{{healthProfile.age || '-'}} 岁</text>
          </view>
          <view class="info-item">
            <text class="info-label">身高</text>
            <text class="info-value">{{healthProfile.height || '-'}} cm</text>
          </view>
          <view class="info-item">
            <text class="info-label">体重</text>
            <text class="info-value">{{healthProfile.weight || '-'}} kg</text>
          </view>
          <view class="info-item">
            <text class="info-label">体型</text>
            <text class="info-value">{{getBodyTypeName(healthProfile.body_type)}}</text>
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="card-header">
          <text class="card-title">身体症状</text>
        </view>
        <view class="tag-list">
          <text 
            class="tag {{healthProfile.symptoms && healthProfile.symptoms.includes(item) ? 'active' : ''}}"
            wx:for="{{symptomsOptions}}"
            wx:key="index"
          >{{item}}</text>
        </view>
      </view>

      <view class="section-card">
        <view class="card-header">
          <text class="card-title">运动损伤</text>
        </view>
        <view class="tag-list">
          <text 
            class="tag {{healthProfile.injuries && healthProfile.injuries.includes(item) ? 'active' : ''}}"
            wx:for="{{injuriesOptions}}"
            wx:key="index"
          >{{item}}</text>
        </view>
      </view>

      <view class="section-card">
        <view class="card-header">
          <text class="card-title">健康目标</text>
        </view>
        <view class="tag-list">
          <text 
            class="tag {{healthProfile.health_goals && healthProfile.health_goals.includes(item) ? 'active' : ''}}"
            wx:for="{{healthGoalsOptions}}"
            wx:key="index"
          >{{item}}</text>
        </view>
      </view>

      <view class="section-card">
        <view class="card-header">
          <text class="card-title">运动频率</text>
        </view>
        <view class="tag-list">
          <text class="tag active">{{getFrequencyName(healthProfile.exercise_frequency)}}</text>
        </view>
      </view>
    </view>

    <!-- ========== 数据导入Tab ========== -->
    <view class="tab-content" wx:if="{{currentTab === 'data'}}">
      <view class="data-source-list">
        <view 
          class="data-source-item"
          wx:for="{{dataSources}}"
          wx:key="platform"
        >
          <view class="source-left">
            <image class="source-icon" src="{{item.icon}}" mode="aspectFit" />
            <view class="source-info">
              <text class="source-name">{{item.name}}</text>
              <text class="source-status {{item.status}}">
                {{item.status === 'connected' ? '已连接' : '未连接'}}
              </text>
              <text class="source-sync" wx:if="{{item.lastSyncTime}}">
                上次同步: {{item.lastSyncTime}}
              </text>
            </view>
          </view>
          <button 
            class="source-action {{item.status}}"
            bindtap="handleDataConnection"
            data-platform="{{item.platform}}"
            data-status="{{item.status}}"
          >
            {{item.status === 'connected' ? '断开' : '连接'}}
          </button>
        </view>
      </view>
    </view>

    <!-- ========== 运动勋章Tab ========== -->
    <view class="tab-content" wx:if="{{currentTab === 'medal'}}">
      <view class="medal-list" wx:if="{{medals.length > 0}}">
        <view 
          class="medal-item"
          wx:for="{{medals}}"
          wx:key="id"
        >
          <view class="medal-icon-wrapper">
            <image class="medal-icon" src="{{item.medal_icon}}" mode="aspectFit" />
          </view>
          <view class="medal-info">
            <text class="medal-name">{{item.medal_name}}</text>
            <text class="medal-condition">{{item.condition}}</text>
            <text class="medal-date">{{item.earned_at}}</text>
          </view>
        </view>
      </view>
      <view class="medal-empty" wx:else>
        <text class="empty-icon">🏅</text>
        <text class="empty-text">还没有获得勋章</text>
        <text class="empty-hint">坚持运动，解锁更多勋章吧！</text>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-section">
      <button class="logout-btn" bindtap="onLogout">退出登录</button>
    </view>
  </view>

  <!-- 编辑个人资料弹窗 -->
  <view class="modal-overlay" wx:if="{{showProfileEdit}}" bindtap="closeProfileEdit">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">编辑个人资料</text>
        <text class="modal-close" bindtap="closeProfileEdit">✕</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">昵称</text>
          <input 
            class="form-input" 
            placeholder="请输入昵称"
            value="{{editForm.nickname}}"
            bindinput="onNicknameInput"
          />
        </view>
        <view class="form-item">
          <text class="form-label">性别</text>
          <picker 
            mode="selector" 
            range="{{genderOptions}}"
            bindchange="onGenderChange"
          >
            <view class="form-picker">
              <text>{{getGenderName(editForm.gender)}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
        <view class="form-item">
          <text class="form-label">生日</text>
          <picker 
            mode="date" 
            bindchange="onBirthdayChange"
            value="{{editForm.birthday}}"
          >
            <view class="form-picker">
              <text>{{editForm.birthday || '请选择'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
        <view class="form-item">
          <text class="form-label">地区</text>
          <input 
            class="form-input" 
            placeholder="请输入地区"
            value="{{editForm.region}}"
            bindinput="onRegionInput"
          />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="closeProfileEdit">取消</button>
        <button class="btn-confirm" bindtap="saveProfileEdit">保存</button>
      </view>
    </view>
  </view>

  <!-- 编辑健康档案弹窗 -->
  <view class="modal-overlay" wx:if="{{showHealthEdit}}" bindtap="closeHealthEdit">
    <view class="modal-content health-modal" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">编辑健康档案</text>
        <text class="modal-close" bindtap="closeHealthEdit">✕</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">年龄</text>
          <input 
            class="form-input" 
            type="number"
            placeholder="请输入年龄"
            value="{{editHealth.age}}"
            bindinput="onAgeInput"
          />
        </view>
        <view class="form-item">
          <text class="form-label">身高 (cm)</text>
          <input 
            class="form-input" 
            type="digit"
            placeholder="请输入身高"
            value="{{editHealth.height}}"
            bindinput="onHeightInput"
          />
        </view>
        <view class="form-item">
          <text class="form-label">体重 (kg)</text>
          <input 
            class="form-input" 
            type="digit"
            placeholder="请输入体重"
            value="{{editHealth.weight}}"
            bindinput="onWeightInput"
          />
        </view>
        <view class="form-item">
          <text class="form-label">体型</text>
          <picker 
            mode="selector" 
            range="{{bodyTypeOptions}}"
            bindchange="onBodyTypeChange"
          >
            <view class="form-picker">
              <text>{{getBodyTypeName(editHealth.body_type)}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
        <view class="form-item">
          <text class="form-label">运动频率</text>
          <picker 
            mode="selector" 
            range="{{frequencyOptions}}"
            range-key="name"
            bindchange="onFrequencyChange"
          >
            <view class="form-picker">
              <text>{{getFrequencyName(editHealth.exercise_frequency)}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
        <view class="form-item vertical">
          <text class="form-label">身体症状</text>
          <view class="tag-grid">
            <text 
              class="tag {{editHealth.symptoms && editHealth.symptoms.includes(item) ? 'active' : ''}}"
              bindtap="toggleSymptom"
              data-symptom="{{item}}"
              wx:for="{{symptomsOptions}}"
              wx:key="index"
            >{{item}}</text>
          </view>
        </view>
        <view class="form-item vertical">
          <text class="form-label">运动损伤</text>
          <view class="tag-grid">
            <text 
              class="tag {{editHealth.injuries && editHealth.injuries.includes(item) ? 'active' : ''}}"
              bindtap="toggleInjury"
              data-injury="{{item}}"
              wx:for="{{injuriesOptions}}"
              wx:key="index"
            >{{item}}</text>
          </view>
        </view>
        <view class="form-item vertical">
          <text class="form-label">健康目标</text>
          <view class="tag-grid">
            <text 
              class="tag {{editHealth.health_goals && editHealth.health_goals.includes(item) ? 'active' : ''}}"
              bindtap="toggleHealthGoal"
              data-goal="{{item}}"
              wx:for="{{healthGoalsOptions}}"
              wx:key="index"
            >{{item}}</text>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="closeHealthEdit">取消</button>
        <button class="btn-confirm" bindtap="saveHealthEdit">保存</button>
      </view>
    </view>
  </view>
</view>

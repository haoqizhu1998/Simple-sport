<!-- pages/user/user.wxml -->
<view class="user-page">
  <!-- 未登录状态 -->
  <view class="login-container" wx:if="{{!isLoggedIn}}">
    <view class="login-avatar">
      <view class="avatar-ring">
        <view class="avatar-inner">
          <text class="avatar-default">S</text>
        </view>
      </view>
    </view>
    <text class="login-title">Simple运动</text>
    
    <!-- 登录表单 -->
    <view class="login-form">
      <view class="form-item">
        <input class="form-input" type="number" placeholder="请输入手机号" bindinput="onPhoneInput" value="{{loginPhone}}" />
      </view>
      <view class="form-item">
        <input class="form-input" type="password" placeholder="请输入密码" bindinput="onPasswordInput" value="{{loginPassword}}" />
      </view>
      <button class="login-btn" bindtap="onLogin">登录</button>
      <button class="register-btn" bindtap="showRegister">注册账号</button>
    </view>
  </view>

  <!-- 注册弹窗 -->
  <view class="modal" wx:if="{{showRegisterModal}}">
    <view class="modal-content">
      <text class="modal-title">注册账号</text>
      <view class="form-item">
        <input class="form-input" type="number" placeholder="手机号" bindinput="onRegPhone" value="{{regPhone}}" />
      </view>
      <view class="form-item">
        <input class="form-input" type="password" placeholder="密码" bindinput="onRegPassword" value="{{regPassword}}" />
      </view>
      <view class="form-item">
        <input class="form-input" type="text" placeholder="昵称" bindinput="onRegNickname" value="{{regNickname}}" />
      </view>
      <view class="modal-btns">
        <button class="cancel-btn" bindtap="hideRegister">取消</button>
        <button class="confirm-btn" bindtap="onRegister">注册</button>
      </view>
    </view>
  </view>

  <!-- 已登录状态 -->
  <view class="logged-container" wx:if="{{isLoggedIn}}">
    <!-- 个人信息卡片 -->
    <view class="profile-card">
      <view class="profile-bg"></view>
      <view class="profile-content">
        <view class="avatar-section">
          <view class="avatar-ring">
            <view class="avatar-inner">
              <image wx:if="{{userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
              <text wx:else class="avatar-text">{{userInfo.nickname ? userInfo.nickname[0] : 'S'}}</text>
            </view>
          </view>
          <view class="user-info">
            <text class="user-name">{{userInfo.nickname || '运动达人'}}</text>
            <view class="level-badge">
              <text class="level-icon">🏆</text>
              <text class="level-text">Lv.{{userInfo.level || 1}}</text>
            </view>
          </view>
        </view>
        <view class="logout-btn" bindtap="onLogout">退出登录</view>
      </view>
    </view>

    <!-- Tab菜单 -->
    <view class="tab-menu">
      <view class="tab-item {{currentTab === 'profile' ? 'active' : ''}}" bindtap="switchTab" data-tab="profile">
        <text class="tab-icon">👤</text>
        <text class="tab-text">个人资料</text>
      </view>
      <view class="tab-item {{currentTab === 'health' ? 'active' : ''}}" bindtap="switchTab" data-tab="health">
        <text class="tab-icon">❤️</text>
        <text class="tab-text">健康档案</text>
      </view>
      <view class="tab-item {{currentTab === 'medal' ? 'active' : ''}}" bindtap="switchTab" data-tab="medal">
        <text class="tab-icon">🏅</text>
        <text class="tab-text">运动勋章</text>
      </view>
    </view>

    <!-- 个人资料Tab -->
    <view class="tab-content" wx:if="{{currentTab === 'profile'}}">
      <view class="info-card">
        <view class="info-item">
          <text class="info-label">昵称</text>
          <text class="info-value">{{userInfo.nickname || '未设置'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">手机号</text>
          <text class="info-value">{{userInfo.phone || '未设置'}}</text>
        </view>
      </view>
    </view>

    <!-- 健康档案Tab -->
    <view class="tab-content" wx:if="{{currentTab === 'health'}}">
      <view class="health-card">
        <view class="health-title">身体信息</view>
        <view class="health-item">
          <text class="health-label">年龄</text>
          <text class="health-value">{{healthProfile.age || '--'}} 岁</text>
        </view>
        <view class="health-item">
          <text class="health-label">身高</text>
          <text class="health-value">{{healthProfile.height || '--'}} cm</text>
        </view>
        <view class="health-item">
          <text class="health-label">体重</text>
          <text class="health-value">{{healthProfile.weight || '--'}} kg</text>
        </view>
        <button class="edit-btn" bindtap="editHealth">编辑健康档案</button>
      </view>
    </view>

    <!-- 勋章Tab -->
    <view class="tab-content" wx:if="{{currentTab === 'medal'}}">
      <view class="medal-list">
        <view class="medal-item" wx:for="{{medals}}" wx:key="id">
          <text class="medal-icon">{{item.medalIcon || '🏅'}}</text>
          <text class="medal-name">{{item.medalName}}</text>
        </view>
        <view class="empty-tip" wx:if="{{medals.length === 0}}">暂无勋章</view>
      </view>
    </view>
  </view>
</view>

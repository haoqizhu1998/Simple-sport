<view class="container">
  <view class="header">
    <text class="title">Simple运动</text>
    <text class="subtitle">登录后同步训练数据</text>
  </view>
  
  <view class="form">
    <input class="input" type="number" placeholder="手机号" bindinput="inputPhone" value="{{phone}}"/>
    <input class="input" type="password" placeholder="密码" bindinput="inputPassword" value="{{password}}"/>
    <button class="btn-login" bindtap="doLogin">登录</button>
    <button class="btn-register" bindtap="doRegister">注册</button>
  </view>
</view>

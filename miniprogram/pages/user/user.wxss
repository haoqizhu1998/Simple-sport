/* pages/user/user.wxss - Sigma深色风格 */

/* ========== 基础变量 ========== */
page {
  --bg-primary: #0a0a0b;
  --bg-card: rgba(255, 255, 255, 0.03);
  --border-card: 1px solid rgba(255, 255, 255, 0.06);
  --gradient-primary: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);
  --gradient-border: linear-gradient(135deg, #8b5cf6, #6366f1);
  --text-primary: #fff;
  --text-secondary: rgba(255, 255, 255, 0.6);
  --text-placeholder: rgba(255, 255, 255, 0.4);
  --radius-card: 24rpx;
  --radius-btn: 16rpx;
}

.user-page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: 120rpx;
}

/* ========== 未登录状态 ========== */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.login-avatar {
  margin-bottom: 60rpx;
}

.avatar-ring {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  padding: 6rpx;
  background: var(--gradient-border);
  box-shadow: 0 8rpx 32rpx rgba(139, 92, 246, 0.3);
}

.avatar-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-default {
  font-size: 72rpx;
  font-weight: 700;
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.login-hint {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 60rpx;
}

.login-btn {
  width: 560rpx;
  height: 96rpx;
  background: var(--gradient-primary);
  border: none;
  border-radius: var(--radius-btn);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 32rpx;
}

.login-btn::after {
  border: none;
}

.login-btn .login-btn-icon {
  margin-right: 12rpx;
}

.guest-btn {
  width: 560rpx;
  height: 80rpx;
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-btn);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.guest-btn::after {
  border: none;
}

/* ========== 已登录状态 ========== */
.logged-container {
  padding: 0 24rpx;
}

/* 个人信息卡片 */
.profile-card {
  position: relative;
  margin-bottom: 32rpx;
  margin-top: 24rpx;
}

.profile-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 380rpx;
  background: linear-gradient(180deg, rgba(139, 92, 246, 0.15) 0%, transparent 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.profile-content {
  position: relative;
  z-index: 1;
  padding: 48rpx 32rpx 32rpx;
  background: var(--bg-card);
  border: var(--border-card);
  border-radius: var(--radius-card);
}

.avatar-section {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: var(--gradient-border);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  display: block;
}

.level-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(139, 92, 246, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.level-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.level-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #a78bfa;
  margin-right: 12rpx;
}

.exp-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.stats-row {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.03);
  border-radius: var(--radius-btn);
  padding: 28rpx 0;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.08);
}

/* Tab菜单 */
.tab-menu {
  display: flex;
  background: var(--bg-card);
  border: var(--border-card);
  border-radius: var(--radius-card);
  padding: 8rpx;
  margin-bottom: 32rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: var(--radius-btn);
  transition: all 0.3s ease;
}

.tab-item.active {
  background: var(--gradient-primary);
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.tab-item.active .tab-text {
  color: var(--text-primary);
  font-weight: 600;
}

/* Tab内容区 */
.tab-content {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 卡片区块 */
.section-card {
  background: var(--bg-card);
  border: var(--border-card);
  border-radius: var(--radius-card);
  margin-bottom: 24rpx;
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.edit-btn {
  font-size: 26rpx;
  color: #a78bfa;
  padding: 8rpx 16rpx;
}

.info-list {
  padding: 0 32rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* 标签列表 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 32rpx;
  gap: 16rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.tag.active {
  background: rgba(139, 92, 246, 0.2);
  border-color: rgba(139, 92, 246, 0.4);
  color: #a78bfa;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

/* 数据源列表 */
.data-source-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.data-source-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--bg-card);
  border: var(--border-card);
  border-radius: var(--radius-card);
  padding: 28rpx 32rpx;
}

.source-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.source-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  background: rgba(255, 255, 255, 0.05);
}

.source-info {
  display: flex;
  flex-direction: column;
}

.source-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.source-status {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.source-status.connected {
  color: #34d399;
}

.source-sync {
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 4rpx;
}

.source-action {
  padding: 16rpx 32rpx;
  border-radius: var(--radius-btn);
  font-size: 26rpx;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.08);
  border: none;
  color: var(--text-primary);
}

.source-action.connected {
  background: rgba(239, 68, 68, 0.2);
  color: #f87171;
}

.source-action::after {
  border: none;
}

/* 勋章列表 */
.medal-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.medal-item {
  background: var(--bg-card);
  border: var(--border-card);
  border-radius: var(--radius-card);
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.medal-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.medal-icon {
  width: 100%;
  height: 100%;
}

.medal-info {
  display: flex;
  flex-direction: column;
}

.medal-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.medal-condition {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.medal-date {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

.medal-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 退出登录 */
.logout-section {
  margin-top: 60rpx;
  padding: 0 32rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: rgba(239, 68, 68, 0.15);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: var(--radius-btn);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #f87171;
}

.logout-btn::after {
  border: none;
}

/* ========== 弹窗样式 ========== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: overlayIn 0.3s ease;
}

@keyframes overlayIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.modal-content {
  width: 100%;
  max-height: 85vh;
  background: #1a1a1b;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  animation: modalSlideUp 0.3s ease;
}

.health-modal {
  max-height: 90vh;
}

@keyframes modalSlideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: 40rpx;
  color: var(--text-secondary);
  padding: 8rpx;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-btn);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-cancel {
  background: rgba(255, 255, 255, 0.08);
  color: var(--text-primary);
  border: none;
}

.btn-confirm {
  background: var(--gradient-primary);
  color: var(--text-primary);
  border: none;
}

.btn-cancel::after,
.btn-confirm::after {
  border: none;
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.form-item.vertical {
  display: flex;
  flex-direction: column;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-btn);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
}

.form-input::placeholder {
  color: var(--text-placeholder);
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-btn);
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--text-primary);
}

.picker-arrow {
  font-size: 36rpx;
  color: var(--text-placeholder);
}

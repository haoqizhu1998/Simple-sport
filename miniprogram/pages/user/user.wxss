.container { min-height: 100vh; background: #0a0a0b; padding: 120rpx 60rpx; }
.header { text-align: center; margin-bottom: 80rpx; }
.title { display: block; font-size: 48rpx; font-weight: bold; color: #fff; margin-bottom: 20rpx; }
.subtitle { display: block; font-size: 28rpx; color: rgba(255,255,255,0.5); }
.form { width: 100%; }
.input { width: 100%; height: 100rpx; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 24rpx; padding: 0 30rpx; box-sizing: border-box; color: #fff; font-size: 32rpx; margin-bottom: 30rpx; }
.btn-login { width: 100%; height: 100rpx; background: linear-gradient(135deg, #8b5cf6, #6366f1); border-radius: 24rpx; color: #fff; font-size: 34rpx; font-weight: bold; margin-bottom: 30rpx; }
.btn-register { width: 100%; height: 100rpx; background: transparent; border: 1px solid rgba(139, 92, 246, 0.5); border-radius: 24rpx; color: #8b5cf6; font-size: 34rpx; }

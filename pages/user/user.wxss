/* pages/user/user.wxss - Sigma深色风格 */

.container {
  min-height: 100vh;
  background: #0a0a0b;
  padding: 0;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 50vh;
  color: #666;
}

/* 未登录状态 */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 40rpx;
  opacity: 0.8;
}

.login-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 20rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 60rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 内容区域 */
.content {
  padding: 30rpx;
}

/* 用户卡片 */
.profile-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(40px);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: rgba(255, 255, 255, 0.1);
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-level {
  font-size: 24rpx;
  color: #667eea;
}

.logout-btn {
  font-size: 26rpx;
  color: #666;
  padding: 12rpx 24rpx;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(40px);
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* 区块 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 20rpx;
}

/* 健康卡片 */
.health-card {
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(40px);
  border-radius: 24rpx;
  padding: 30rpx;
}

.health-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.health-row:last-of-type {
  border-bottom: none;
}

.health-label {
  font-size: 28rpx;
  color: #888;
}

.health-value {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.edit-btn {
  width: 100%;
  margin-top: 24rpx;
  height: 80rpx;
  background: rgba(102, 126, 234, 0.15);
  border-radius: 40rpx;
  color: #667eea;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 勋章墙 */
.medals-card {
  display: flex;
  flex-wrap: wrap;
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(40px);
  border-radius: 24rpx;
  padding: 30rpx;
}

.medal-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.medal-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
}

.medal-name {
  font-size: 22rpx;
  color: #888;
  text-align: center;
}

/* 数据连接 */
.connection-list {
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(40px);
  border-radius: 24rpx;
  padding: 10rpx 0;
}

.connection-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.connection-item.connected {
  opacity: 0.7;
}

.connection-item:last-of-type {
  border-bottom: none;
}

.connection-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.connection-name {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
}

.connection-status {
  font-size: 24rpx;
  color: #666;
}

.add-connection-btn {
  width: 100%;
  height: 88rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 0;
  color: #667eea;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 10rpx;
}

/* 菜单列表 */
.menu-list {
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(40px);
  border-radius: 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
}

.menu-text.danger {
  color: #ff6b6b;
}

.menu-arrow {
  font-size: 32rpx;
  color: #444;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #1a1a1b;
  border-radius: 24rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #fff;
  box-sizing: border-box;
}

.modal-buttons {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 10rpx;
}

.modal-btn.cancel {
  background: rgba(255, 255, 255, 0.05);
  color: #888;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 平台列表 */
.platform-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.platform-btn {
  width: 48%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  color: #fff;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

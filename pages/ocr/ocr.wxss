/* pages/ocr/ocr.wxss - Sigma深色风格 */
.container {
  min-height: 100vh;
  background: #0a0a0f;
  color: #fff;
  padding: 30rpx;
}

/* 页面标题 */
.page-header {
  margin-bottom: 40rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
}

/* 支持的平台 */
.platform-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 24rpx;
}

.platform-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.platform-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 24rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.platform-icon {
  font-size: 32rpx;
}

.platform-name {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* 上传区域 */
.upload-section {
  margin-bottom: 40rpx;
}

.upload-area {
  width: 100%;
  height: 400rpx;
  background: rgba(255,255,255,0.03);
  border: 2rpx dashed rgba(255,255,255,0.2);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.upload-icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.upload-text {
  font-size: 30rpx;
  color: rgba(255,255,255,0.6);
}

.upload-hint {
  font-size: 24rpx;
  color: rgba(255,255,255,0.3);
}

.preview-image {
  width: 100%;
  height: 100%;
}

.rechoose-btn {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
  padding: 20rpx;
  color: #7c5cff;
  font-size: 28rpx;
}

/* 识别结果 */
.result-section {
  margin-bottom: 40rpx;
}

.result-header {
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4ade80;
}

.result-card {
  background: rgba(255,255,255,0.05);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}

.result-item:last-child {
  border-bottom: none;
}

.result-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
}

.result-value {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

.type-tag {
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.type-tag.run {
  background: rgba(124,92,255,0.2);
  color: #a78bfa;
}

.type-tag.bike {
  background: rgba(34,211,238,0.2);
  color: #22d3ee;
}

.type-tag.swim {
  background: rgba(74,222,128,0.2);
  color: #4ade80;
}

/* 操作按钮 */
.action-btns {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 32rpx;
}

.btn-save {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #7c5cff 0%, #a78bfa 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-cancel {
  width: 100%;
  height: 88rpx;
  background: rgba(255,255,255,0.05);
  color: rgba(255,255,255,0.6);
  border-radius: 44rpx;
  font-size: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}

/* 提示卡片 */
.tips-section {
  margin-top: 40rpx;
}

.tips-card {
  background: rgba(255,255,255,0.03);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}

.tips-header {
  font-size: 28rpx;
  font-weight: 600;
  color: #fbbf24;
  margin-bottom: 24rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tips-item {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  line-height: 1.6;
}

/* 加载中 */
.loading-section {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10,10,15,0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid rgba(124,92,255,0.2);
  border-top-color: #7c5cff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  color: #fff;
}

.loading-hint {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
}

/* pages/history/history.wxss - Sigma深色风格 */
.container {
  min-height: 100vh;
  background: #0a0a0b;
  padding-bottom: 120rpx;
}

/* 头部区域 */
.header {
  padding: 120rpx 40rpx 32rpx;
  background: linear-gradient(180deg, #0a0a0b 0%, #12121a 100%);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.header-date {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 统计卡片 */
.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 32rpx 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

.stat-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.08);
}

/* 筛选区域 */
.filter-section {
  padding: 24rpx 0;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-tabs {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 40rpx;
}

.filter-tab {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  white-space: nowrap;
}

.filter-tab.active {
  background: rgba(139, 92, 246, 0.15);
  border-color: rgba(139, 92, 246, 0.3);
}

.tab-icon {
  font-size: 28rpx;
}

.tab-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.filter-tab.active .tab-text {
  color: #a78bfa;
  font-weight: 600;
}

/* 训练列表 */
.history-list {
  padding: 0 40rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  margin-bottom: 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
}

/* 左侧评分 */
.item-score {
  margin-right: 24rpx;
}

.score-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.3);
}

.score-value {
  font-size: 28rpx;
  font-weight: 700;
}

/* 中间内容 */
.item-content {
  flex: 1;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-type {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.type-icon {
  font-size: 32rpx;
}

.type-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.item-date {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 数据标签 */
.item-stats {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.stat-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.tag-icon {
  font-size: 20rpx;
}

.tag-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.tag-unit {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 底部质量标签 */
.item-footer {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.quality-badge {
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.quality-badge.excellent {
  background: rgba(34, 197, 94, 0.15);
  color: #22c55e;
}

.quality-badge.good {
  background: rgba(59, 130, 246, 0.15);
  color: #3b82f6;
}

.quality-badge.average {
  background: rgba(251, 191, 36, 0.15);
  color: #fbbf24;
}

.quality-badge.poor {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

.quality-text {
  font-size: 20rpx;
  font-weight: 600;
}

.quality-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 右侧箭头 */
.item-arrow {
  margin-left: 16rpx;
  color: rgba(255, 255, 255, 0.3);
  font-size: 40rpx;
  font-weight: 300;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 48rpx;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 320rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 10rpx 40rpx rgba(139, 92, 246, 0.3);
}

.btn-icon {
  font-size: 36rpx;
}

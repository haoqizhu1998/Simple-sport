/* pages/history/history.wxss - Sigma风格 */
.container {
  min-height: 100vh;
  background: #0a0a0b;
  padding: 0;
  padding-bottom: 120rpx;
}

.header {
  padding: 120rpx 40rpx 40rpx;
  background: linear-gradient(180deg, #0a0a0b 0%, #12121a 100%);
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.stats-bar {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 0;
  margin-top: 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 24rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 4rpx;
}

.filter-tabs {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 40rpx;
}

.filter-tab {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.filter-tab.active {
  background: rgba(139, 92, 246, 0.2);
  border-color: rgba(139, 92, 246, 0.4);
  color: #a78bfa;
}

.record-list {
  padding: 0 40rpx;
}

.date-group {
  margin-bottom: 32rpx;
}

.date-header {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 16rpx;
}

.record-card {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-type {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.type-icon {
  font-size: 36rpx;
}

.type-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.record-score {
  padding: 6rpx 16rpx;
  background: rgba(34, 197, 94, 0.15);
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #22c55e;
}

.record-stats {
  display: flex;
  gap: 32rpx;
}

.record-stat {
  display: flex;
  flex-direction: column;
}

.record-stat-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.record-stat-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
}

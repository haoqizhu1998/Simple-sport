<!-- pages/history/history.wxml -->
<view class="history-page">
  <!-- 统计概览 -->
  <view class="stats-overview">
    <view class="overview-bg"></view>
    <view class="overview-content">
      <view class="stats-grid">
        <view class="stat-item">
          <view class="stat-value">{{totalStats.count}}</view>
          <view class="stat-label">训练次数</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-value">{{totalStats.distance}}</view>
          <view class="stat-label">总公里数</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-value">{{totalStats.avgScore}}</view>
          <view class="stat-label">平均评分</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-section">
    <view class="filter-tabs">
      <view 
        class="filter-tab {{selectedFilter === item.key ? 'active' : ''}}"
        wx:for="{{filterOptions}}"
        wx:key="key"
        bindtap="onFilterChange"
        data-key="{{item.key}}"
      >
        {{item.name}}
      </view>
    </view>
  </view>

  <!-- 训练记录列表 -->
  <view class="history-list" wx:if="{{!isEmpty}}">
    <view 
      class="history-item"
      wx:for="{{filteredList}}"
      wx:key="id"
      bindtap="viewDetail"
      data-id="{{item.id}}"
    >
      <!-- 左侧分数 -->
      <view class="item-score">
        <view class="score-circle" style="border-color: {{getScoreColor(item.score)}}">
          <text class="score-value" style="color: {{getScoreColor(item.score)}}">{{item.score}}</text>
        </view>
      </view>

      <!-- 中间信息 -->
      <view class="item-content">
        <view class="item-header">
          <view class="item-type">
            <text class="type-icon">{{getTypeIcon(item.trainingType)}}</text>
            <text class="type-name">{{item.trainingType}}</text>
          </view>
          <view class="item-date">{{item.dateStr}}</view>
        </view>

        <view class="item-stats">
          <view class="stat-tag">
            <text class="tag-value">{{item.distance}}</text>
            <text class="tag-unit">km</text>
          </view>
          <view class="stat-tag">
            <text class="tag-value">{{item.paceStr || item.pace}}</text>
            <text class="tag-unit">/km</text>
          </view>
          <view class="stat-tag">
            <text class="tag-value">{{item.duration}}</text>
            <text class="tag-unit">时长</text>
          </view>
        </view>

        <view class="item-quality">
          <view class="quality-badge {{item.quality}}">{{item.quality}}</view>
          <text class="quality-desc">{{item.qualityDesc}}</text>
        </view>
      </view>

      <!-- 删除按钮 -->
      <view class="item-action" catchtap="deleteRecord" data-id="{{item.id}}" data-index="{{index}}">
        <text>🗑️</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{isEmpty}}">
    <image src="/assets/icons/empty-history.png" mode="aspectFit"></image>
    <text class="empty-title">暂无训练记录</text>
    <text class="empty-desc">开始记录你的第一次训练吧</text>
    <button class="btn-primary" bindtap="goToReview">开始训练</button>
  </view>
</view>

<!-- pages/profile/profile.wxml -->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="profile-card">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatarUrl || '/assets/icons/profile.png'}}" mode="aspectFill"></image>
      <view class="user-detail" wx:if="{{userInfo.nickName}}">
        <text class="user-name">{{userInfo.nickName}}</text>
        <text class="user-id">运动达人</text>
      </view>
      <button class="login-btn" wx:if="{{!userInfo.nickName}}" open-type="getUserInfo" bindgetuserinfo="onGotUserInfo">
        登录
      </button>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-value">{{stats.totalTrainings}}</text>
      <text class="stat-label">训练次数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{stats.totalDistance}}</text>
      <text class="stat-label">总里程(km)</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{stats.totalDays}}</text>
      <text class="stat-label">训练天数</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="showBodyStatusModal">
      <text class="menu-icon">💪</text>
      <text class="menu-text">身体状态</text>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item" bindtap="showRaceModal">
      <text class="menu-icon">🏆</text>
      <text class="menu-text">目标赛事</text>
      <text class="menu-value">{{currentRace.name || '未设置'}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="about">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item danger" bindtap="clearAllData">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">清空数据</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 身体状态弹窗 -->
  <view class="modal" wx:if="{{showBodyStatus}}" catchtouchmove="preventTouchMove">
    <view class="modal-mask" bindtap="hideBodyStatusModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">今日身体状态</text>
      </view>
      <view class="modal-body">
        <view class="slider-item">
          <text class="slider-label">睡眠时长</text>
          <slider min="0" max="10" value="{{bodyStatus.sleep}}" bindchange="onSleepChange" show-value/>
        </view>
        <view class="slider-item">
          <text class="slider-label">疲劳程度</text>
          <slider min="1" max="10" value="{{bodyStatus.fatigue}}" bindchange="onFatigueChange" show-value/>
        </view>
        <view class="slider-item">
          <text class="slider-label">心情指数</text>
          <slider min="1" max="10" value="{{bodyStatus.mood}}" bindchange="onMoodChange" show-value/>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="hideBodyStatusModal">取消</button>
        <button class="modal-btn confirm" bindtap="saveBodyStatus">保存</button>
      </view>
    </view>
  </view>

  <!-- 赛事设置弹窗 -->
  <view class="modal" wx:if="{{showRaceModal}}" catchtouchmove="preventTouchMove">
    <view class="modal-mask" bindtap="hideRaceModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">设置目标赛事</text>
      </view>
      <view class="modal-body">
        <view class="input-item">
          <text class="input-label">赛事名称</text>
          <input class="input-field" placeholder="如：2026北京马拉松" bindinput="onRaceNameInput" value="{{newRaceName}}"/>
        </view>
        <view class="input-item">
          <text class="input-label">比赛日期</text>
          <picker mode="date" bindchange="onRaceDateChange">
            <view class="picker-value">{{newRaceDate || '选择日期'}}</view>
          </picker>
        </view>
        <view class="input-item">
          <text class="input-label">赛事类型</text>
          <picker mode="selector" range="{{raceTypes}}" range-key="name" bindchange="onRaceTypeChange">
            <view class="picker-value">{{newRaceTypeText || '选择类型'}}</view>
          </picker>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-btn cancel" bindtap="hideRaceModal">取消</button>
        <button class="modal-btn confirm" bindtap="saveRace">保存</button>
      </view>
    </view>
  </view>
</view>

/* pages/profile/profile.wxss */
.profile-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 60rpx;
}

/* 用户信息卡片 */
.profile-card {
  position: relative;
  margin-bottom: 30rpx;
}

.profile-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 320rpx;
  background: linear-gradient(135deg, #1A1A2E 0%, #16213E 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.profile-content {
  position: relative;
  z-index: 1;
  padding: 60rpx 30rpx 30rpx;
}

.avatar-section {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #00D9FF 0%, #00B4D8 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 217, 255, 0.3);
}

.avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.user-type {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.stats-row {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 30rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 区块样式 */
.section {
  margin: 0 30rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.section-content {
  padding: 10rpx 30rpx 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.info-value.highlight {
  color: #00D9FF;
}

.info-empty {
  padding: 30rpx 0;
  text-align: center;
}

.info-empty text {
  font-size: 26rpx;
  color: #999;
}

/* 编辑按钮 */
.edit-section {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.edit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: #FFFFFF;
  border: 2rpx solid #00D9FF;
  border-radius: 50rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #00D9FF;
}

.edit-icon {
  font-size: 32rpx;
}

/* 编辑表单 */
.edit-form {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.form-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
}

.picker-arrow {
  font-size: 36rpx;
  color: #999;
}

.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  background: #F5F5F5;
  color: #666;
  border: none;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-save {
  flex: 2;
  height: 88rpx;
  background: linear-gradient(135deg, #00D9FF 0%, #00B4D8 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(0, 217, 255, 0.3);
}

/* 功能菜单 */
.menu-section {
  margin: 0 30rpx 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F8F8F8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger .menu-left .menu-icon,
.menu-item.danger .menu-left .menu-text {
  color: #FF6B6B;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #CCC;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 30rpx;
}

.version-info text {
  font-size: 24rpx;
  color: #CCC;
}

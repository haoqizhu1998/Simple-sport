/* pages/profile/profile.wxss - Sigma风格 */
.container {
  min-height: 100vh;
  background: #0a0a0b;
  padding: 0;
  padding-bottom: 40rpx;
}

.profile-card {
  padding: 120rpx 40rpx 60rpx;
  background: linear-gradient(180deg, #12121a 0%, #0a0a0b 100%);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 3rpx solid #8b5cf6;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.user-tag {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 6rpx;
}

.stats-card {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
  margin: 24rpx 40rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 6rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.08);
}

.menu-section {
  margin: 24rpx 40rpx;
}

.menu-group {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #fff;
}

.menu-value {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.2);
}

.menu-item.danger .menu-text {
  color: #ef4444;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 85%;
  background: #1a1a1f;
  border-radius: 32rpx;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx;
  text-align: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.modal-body {
  padding: 32rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  background: transparent;
  border: none;
}

.modal-btn.cancel {
  color: rgba(255, 255, 255, 0.5);
}

.modal-btn.confirm {
  color: #8b5cf6;
  font-weight: 600;
}

.slider-item {
  margin-bottom: 32rpx;
}

.slider-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-bottom: 12rpx;
}

.input-item {
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  display: block;
  margin-bottom: 12rpx;
}

.input-field {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #fff;
}

.picker-value {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

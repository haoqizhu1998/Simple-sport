/* pages/review/review.wxss - Sigma深色风格 */
.container, .review-page {
  min-height: 100vh;
  background: #0a0a0f;
  padding: 0;
  padding-bottom: 200rpx;
}

.page-header {
  padding: 120rpx 40rpx 40rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
}

.form-container {
  padding: 0 40rpx;
}

.input-group {
  margin-bottom: 40rpx;
}

.input-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.label-icon {
  font-size: 32rpx;
}

.input-label text:nth-child(2) {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.label-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 运动类型选择 */
.type-selector {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.type-btn {
  padding: 24rpx 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.2s;
}

.type-btn.active {
  background: rgba(139, 92, 246, 0.15);
  border-color: rgba(139, 92, 246, 0.5);
}

.type-icon {
  font-size: 40rpx;
}

.type-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.type-btn.active .type-name {
  color: #a78bfa;
}

/* 输入框 */
.input-field {
  width: 100%;
  padding: 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #fff;
  box-sizing: border-box;
}

.input-field::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

/* 配速输入组 */
.pace-input-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pace-input {
  flex: 1;
  padding: 24rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #fff;
  text-align: center;
}

.pace-input::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.pace-separator {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  flex-shrink: 0;
}

/* RPE选择器 */
.rpe-selector {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
}

.rpe-option {
  flex: 1;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  transition: all 0.2s;
}

.rpe-option.active {
  background: rgba(139, 92, 246, 0.2);
  border-color: rgba(139, 92, 246, 0.5);
  color: #a78bfa;
  font-weight: 600;
}

.rpe-hints {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
}

.rpe-hints text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 图片上传 */
.image-upload-area {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx dashed rgba(255, 255, 255, 0.15);
  border-radius: 20rpx;
  padding: 24rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.image-item.main {
  border: 2rpx solid #7c5cff;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
}

.main-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8rpx;
  background: rgba(124, 92, 255, 0.8);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
}

.upload-btn {
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx dashed rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.upload-icon {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.3);
}

.upload-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, #0a0a0f 80%, transparent);
  display: flex;
  gap: 20rpx;
}

.btn-secondary {
  flex: 1;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.6);
}

.btn-primary {
  flex: 2;
  height: 96rpx;
  background: linear-gradient(135deg, #7c5cff 0%, #a78bfa 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 10rpx 40rpx rgba(124, 92, 255, 0.4);
}

.btn-primary.loading {
  opacity: 0.7;
}

.btn-content, .loading-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.btn-icon {
  font-size: 32rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* result页面 */
.result-container {
  min-height: 100vh;
  background: #0a0a0f;
  padding: 0 40rpx 60rpx;
}

.result-header {
  padding: 120rpx 0 40rpx;
  text-align: center;
}

.result-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.result-score {
  font-size: 100rpx;
  font-weight: 800;
  color: #7c5cff;
}

.score-card {
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 28rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-icon {
  font-size: 32rpx;
}

.analysis-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
}

.advice-card {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.1) 0%, rgba(16, 185, 129, 0.1) 100%);
  border-color: rgba(34, 197, 94, 0.2);
}

.advice-title {
  color: #22c55e;
}

.back-btn {
  width: 100%;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #fff;
}

/* pages/review/review.wxss - Sigma风格 */
.container {
  min-height: 100vh;
  background: #0a0a0b;
  padding: 0;
  padding-bottom: 200rpx;
}

.header {
  padding: 120rpx 40rpx 40rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
}

.form-section {
  padding: 0 40rpx;
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16rpx;
  display: block;
}

.type-selector {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.type-btn {
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.type-btn.active {
  background: rgba(139, 92, 246, 0.15);
  border-color: rgba(139, 92, 246, 0.4);
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.type-name {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.input-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.input-item {
  flex: 1;
}

.input-field {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #fff;
}

.input-unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
  text-align: center;
}

.slider-item {
  margin-bottom: 32rpx;
}

.slider-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.slider-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.slider-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #8b5cf6;
}

.notes-area {
  margin-bottom: 24rpx;
}

.notes-input {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #fff;
  min-height: 120rpx;
  text-align: left;
}

.submit-btn {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 10rpx 40rpx rgba(139, 92, 246, 0.4);
}

/* result页面 */
.result-container {
  min-height: 100vh;
  background: #0a0a0b;
  padding: 0 40rpx 60rpx;
}

.result-header {
  padding: 120rpx 0 40rpx;
  text-align: center;
}

.result-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.result-score {
  font-size: 100rpx;
  font-weight: 800;
  color: #8b5cf6;
}

.score-card {
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 28rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-icon {
  font-size: 32rpx;
}

.analysis-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
}

.advice-card {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.1) 0%, rgba(16, 185, 129, 0.1) 100%);
  border-color: rgba(34, 197, 94, 0.2);
}

.advice-title {
  color: #22c55e;
}

.back-btn {
  width: 100%;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #fff;
}

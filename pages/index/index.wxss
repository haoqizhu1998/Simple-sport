/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1A1A2E 0%, #16213E 100%);
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 登录卡片 */
.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  margin-top: 200rpx;
}

.login-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 40rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 60rpx;
}

.login-btn {
  width: 80%;
  background: linear-gradient(135deg, #00D9FF 0%, #007AFF 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  margin-bottom: 24rpx;
}

.guest-btn {
  width: 80%;
  background: transparent;
  color: #999;
  border: 1rpx solid #666;
  border-radius: 50rpx;
  font-size: 28rpx;
}

/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 10rpx;
  margin-bottom: 30rpx;
}

.greeting {
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: 28rpx;
  color: #999;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 8rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #00D9FF;
}

/* 卡片通用样式 */
.card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.card-action {
  font-size: 24rpx;
  color: #00D9FF;
}

/* 身体状态 */
.status-card {
  border-left: 6rpx solid #00D9FF;
}

.status-bars {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.status-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.status-label {
  width: 80rpx;
  font-size: 28rpx;
  color: #ccc;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-fill.sleep {
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
}

.progress-fill.fatigue {
  background: linear-gradient(90deg, #f093fb 0%, #f5576c 100%);
}

.progress-fill.mood {
  background: linear-gradient(90deg, #4facfe 0%, #00f2fe 100%);
}

.status-value {
  width: 80rpx;
  font-size: 28rpx;
  color: #fff;
  text-align: right;
}

/* AI建议 */
.suggestion-card {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  background: linear-gradient(135deg, rgba(0, 217, 255, 0.1) 0%, rgba(0, 122, 255, 0.1) 100%);
  border: 1rpx solid rgba(0, 217, 255, 0.3);
}

.suggestion-icon {
  font-size: 48rpx;
}

.suggestion-content {
  flex: 1;
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #00D9FF;
  display: block;
  margin-bottom: 8rpx;
}

.suggestion-text {
  font-size: 28rpx;
  color: #fff;
  line-height: 1.5;
}

/* 今日活动 */
.today-stats {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.stat {
  font-size: 36rpx;
  font-weight: bold;
  color: #00D9FF;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.activity-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.activity-info {
  display: flex;
  flex-direction: column;
}

.activity-type {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.activity-detail {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.activity-score {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score {
  font-size: 36rpx;
  font-weight: bold;
  color: #00D9FF;
}

.score-label {
  font-size: 22rpx;
  color: #999;
}

.activity-empty {
  padding: 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
}

/* 本周训练 */
.week-chart {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 200rpx;
  padding-top: 20rpx;
}

.week-bar-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}

.week-bar {
  width: 40rpx;
  background: linear-gradient(180deg, #00D9FF 0%, #007AFF 100%);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 8rpx;
  margin-top: auto;
}

.week-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #00D9FF 0%, #007AFF 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 217, 255, 0.3);
}

.add-icon {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.add-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

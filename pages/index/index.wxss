/* pages/index/index.wxss - Sigma风格新版首页 */
.container {
  min-height: 100vh;
  background: #0a0a0b;
  padding: 0;
  padding-bottom: 120rpx;
}

/* 头部区域 */
.header {
  padding: 100rpx 40rpx 40rpx;
  background: linear-gradient(180deg, #0a0a0b 0%, #12121a 100%);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.greeting {
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: -1rpx;
}

.date-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 6rpx;
}

.status-badge {
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-badge.good {
  background: rgba(34, 197, 94, 0.15);
  color: #22c55e;
}

.status-badge.normal {
  background: rgba(251, 191, 36, 0.15);
  color: #fbbf24;
}

.status-badge.bad {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

/* 三项运动 */
.sports-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.sport-card {
  padding: 24rpx 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.sport-icon {
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.sport-info {
  margin-bottom: 8rpx;
}

.sport-distance {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.sport-pace {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.sport-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 训练时长+卡路里 */
.stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

.stat-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.08);
}

/* AI建议区块 */
.ai-section {
  margin: 24rpx 40rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.12) 0%, rgba(59, 130, 246, 0.12) 100%);
  border: 1px solid rgba(139, 92, 246, 0.2);
  border-radius: 28rpx;
}

.ai-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.ai-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(139, 92, 246, 0.2);
  border-radius: 16rpx;
}

.ai-icon {
  font-size: 24rpx;
}

.ai-text {
  font-size: 24rpx;
  color: #a78bfa;
  font-weight: 500;
}

.ai-team {
  display: flex;
  gap: 8rpx;
}

.team-tag {
  padding: 6rpx 12rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 10rpx;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.5);
}

.ai-content {
  margin-bottom: 20rpx;
}

.ai-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #a78bfa;
  display: block;
  margin-bottom: 8rpx;
}

.ai-main {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.ai-details {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.6;
  display: block;
}

.ai-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.ai-tag {
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.ai-footer {
  padding-top: 20rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.coach-note {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-style: italic;
}

/* 训练录入区块 */
.input-section {
  margin: 24rpx 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.week-total {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.input-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.input-card {
  padding: 32rpx 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.input-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.input-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 6rpx;
}

.input-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.brand-hint {
  text-align: center;
  padding: 16rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 本周趋势 */
.week-section {
  margin: 24rpx 40rpx;
}

.week-chart {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
}

.chart-bars {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 160rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar {
  width: 36rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 8rpx;
  min-height: 4rpx;
  margin-top: auto;
  transition: all 0.3s;
}

.bar.active {
  background: linear-gradient(180deg, #8b5cf6 0%, #3b82f6 100%);
}

.bar-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 10rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(10, 10, 11, 0.9);
  backdrop-filter: blur(40px);
}

.action-btn {
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);
  color: #fff;
  box-shadow: 0 10rpx 40rpx rgba(139, 92, 246, 0.3);
}

.action-icon {
  font-size: 36rpx;
}

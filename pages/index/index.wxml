<!-- pages/index/index.wxml -->
<view class="index-page">
  <!-- 顶部欢迎区域 -->
  <view class="header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="greeting">{{greeting}}，{{userName}}</view>
      <view class="date">{{todayDate}}</view>
    </view>
  </view>

  <!-- 今日数据卡片 -->
  <view class="today-card">
    <view class="today-header">
      <text class="today-title">今日训练</text>
      <text class="today-subtitle">{{todayDate}}</text>
    </view>
    
    <view class="stats-container">
      <view class="stat-item">
        <view class="stat-value">{{todayStats.distance}}</view>
        <view class="stat-unit">公里</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">{{todayStats.duration}}</view>
        <view class="stat-unit">时长</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">{{todayStats.count}}</view>
        <view class="stat-unit">次数</view>
      </view>
    </view>

    <view class="quick-action" bindtap="goToReview">
      <view class="action-icon">
        <image src="/assets/icons/add.png" mode="aspectFit"></image>
      </view>
      <text class="action-text">添加训练记录</text>
      <view class="action-arrow">›</view>
    </view>
  </view>

  <!-- 本周趋势 -->
  <view class="card week-card">
    <view class="section-title">本周训练量</view>
    <view class="week-chart">
      <view class="chart-bars">
        <view class="bar-item" wx:for="{{weekLabels}}" wx:key="index">
          <view class="bar-wrapper">
            <view class="bar" style="height: {{weekData[index] > 0 ? (weekData[index] / 20 * 100) : 5}}%"></view>
          </view>
          <text class="bar-value" wx:if="{{weekData[index] > 0}}">{{weekData[index]}}</text>
          <text class="bar-label">{{weekLabels[index]}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 最近训练 -->
  <view class="card recent-card" wx:if="{{recentTraining.length > 0}}">
    <view class="section-header">
      <view class="section-title">最近训练</view>
      <view class="more-btn" bindtap="goToHistory">查看全部 ›</view>
    </view>
    
    <view class="training-list">
      <view 
        class="training-item" 
        wx:for="{{recentTraining}}" 
        wx:key="index"
        bindtap="viewTrainingDetail"
        data-id="{{item.id}}"
      >
        <view class="training-info">
          <view class="training-type {{item.typeClass}}">{{item.trainingType}}</view>
          <view class="training-date">{{item.dateStr}}</view>
        </view>
        <view class="training-stats">
          <view class="stat">
            <text class="value">{{item.distance}}</text>
            <text class="unit">km</text>
          </view>
          <view class="stat">
            <text class="value">{{item.pace}}</text>
            <text class="unit">/km</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{recentTraining.length === 0 && !isLoading}}">
    <image src="/assets/icons/empty.png" mode="aspectFit"></image>
    <text>还没有训练记录</text>
    <text class="empty-hint">点击下方按钮开始记录</text>
    <button class="btn-primary" bindtap="goToReview">记录第一次训练</button>
  </view>
</view>

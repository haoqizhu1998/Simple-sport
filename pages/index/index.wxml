<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="greeting">
      <text class="greeting-text">{{greeting}}</text>
      <text class="date-text">{{currentDate}}</text>
    </view>
    <view class="weather">
      <text class="weather-icon">☀️</text>
      <text class="weather-temp">24°C</text>
    </view>
  </view>

  <!-- 身体状态 -->
  <view class="status-section">
    <view class="section-title">
      <text>身体状态</text>
      <view class="status-tags">
        <text class="tag {{bodyStatus.tagClass}}">{{bodyStatus.tagText}}</text>
      </view>
    </view>
    <view class="status-cards">
      <view class="status-card">
        <view class="status-icon sleep">😴</view>
        <text class="status-value">{{bodyStatus.sleep}}h</text>
        <text class="status-label">睡眠</text>
      </view>
      <view class="status-card">
        <view class="status-icon energy">⚡</view>
        <text class="status-value">{{10 - bodyStatus.fatigue}}</text>
        <text class="status-label">活力值</text>
      </view>
      <view class="status-card">
        <view class="status-icon mood">😊</view>
        <text class="status-value">{{bodyStatus.mood}}</text>
        <text class="status-label">心情</text>
      </view>
    </view>
  </view>

  <!-- AI建议 -->
  <view class="suggestion-section">
    <view class="ai-badge">
      <text class="ai-icon">✨</text>
      <text class="ai-text">AI建议</text>
    </view>
    <view class="suggestion-content">
      <text class="suggestion-main">{{trainingSuggestion.main}}</text>
      <text class="suggestion-sub">{{trainingSuggestion.sub}}</text>
    </view>
    <view class="suggestion-tags">
      <text class="tag-item" wx:for="{{trainingSuggestion.tags}}" wx:key="index">{{item}}</text>
    </view>
  </view>

  <!-- 今日训练 -->
  <view class="today-section">
    <view class="section-title">
      <text>今日训练</text>
      <view class="today-stats">
        <text class="stat-num">{{todayStats.distance}}</text>
        <text class="stat-unit">km</text>
        <text class="stat-sep">·</text>
        <text class="stat-num">{{todayStats.count}}</text>
        <text class="stat-unit">次</text>
      </view>
    </view>
    
    <view wx:if="{{todayTrainings.length > 0}}" class="training-list">
      <view class="training-item" wx:for="{{todayTrainings}}" wx:key="id" bindtap="viewDetail" data-id="{{item.id}}">
        <view class="training-left">
          <view class="training-type {{item.type}}">{{item.typeIcon}}</view>
          <view class="training-info">
            <text class="training-name">{{item.typeText}}</text>
            <text class="training-time">{{item.duration}}min · {{item.avgHR}}bpm</text>
          </view>
        </view>
        <view class="training-right">
          <text class="training-distance">{{item.distance}}km</text>
          <text class="training-score {{item.scoreClass}}">{{item.scoreText}}</text>
        </view>
      </view>
    </view>
    
    <view wx:else class="empty-training">
      <text class="empty-text">今日暂无训练</text>
    </view>
  </view>

  <!-- 本周趋势 -->
  <view class="week-section">
    <view class="section-title">
      <text>本周趋势</text>
      <text class="week-total">本周 {{weekTotal}}km</text>
    </view>
    <view class="week-chart">
      <view class="chart-bars">
        <view class="bar-item" wx:for="{{weekData}}" wx:key="index">
          <view class="bar {{item.active ? 'active' : ''}}" style="height: {{item.height}}rpx"></view>
          <text class="bar-label">{{weekLabels[index]}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快速操作 -->
  <view class="action-section">
    <button class="action-btn primary" bindtap="goToReview">
      <text class="action-icon">+</text>
      <text class="action-text">录入训练</text>
    </button>
    <button class="action-btn secondary" bindtap="goToHistory">
      <text class="action-icon">📊</text>
      <text class="action-text">训练记录</text>
    </button>
  </view>
</view>

<!-- pages/index/index.wxml - 新版首页 -->
<view class="container">
  <!-- 顶部：今日运动概览 -->
  <view class="header">
    <view class="header-top">
      <view class="greeting">
        <text class="greeting-text">{{greeting}}</text>
        <text class="date-text">{{currentDate}}</text>
      </view>
      <view class="status-badge {{bodyStatus.tagClass}}">
        <text>{{bodyStatus.tagText}}</text>
      </view>
    </view>
    
    <!-- 今日运动总览 -->
    <view class="today-overview">
      <view class="overview-main">
        <text class="overview-value">{{todayStats.totalDistance}}</text>
        <text class="overview-unit">km</text>
      </view>
      <view class="overview-label">今日总里程</view>
    </view>
    
    <!-- 运动数据网格 -->
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-icon">⏱️</text>
        <text class="stat-value">{{todayStats.totalDuration}}</text>
        <text class="stat-label">训练时长</text>
      </view>
      <view class="stat-card">
        <text class="stat-icon">🔥</text>
        <text class="stat-value">{{todayStats.calories}}</text>
        <text class="stat-label">消耗卡路里</text>
      </view>
    </view>
    
    <!-- 三项运动数据 -->
    <view class="sports-grid">
      <view class="sport-card run" bindtap="goToReview" data-type="run">
        <text class="sport-icon">🏃</text>
        <view class="sport-info">
          <text class="sport-distance">{{todayStats.running.distance}}km</text>
          <text class="sport-pace">{{todayStats.running.pace}}/km</text>
        </view>
        <text class="sport-label">跑步</text>
      </view>
      <view class="sport-card bike" bindtap="goToReview" data-type="bike">
        <text class="sport-icon">🚴</text>
        <view class="sport-info">
          <text class="sport-distance">{{todayStats.cycling.distance}}km</text>
          <text class="sport-pace">{{todayStats.cycling.pace}}km/h</text>
        </view>
        <text class="sport-label">骑行</text>
      </view>
      <view class="sport-card swim" bindtap="goToReview" data-type="swim">
        <text class="sport-icon">🏊</text>
        <view class="sport-info">
          <text class="sport-distance">{{todayStats.swimming.distance}}km</text>
          <text class="sport-pace">{{todayStats.swimming.pace}}/100m</text>
        </view>
        <text class="sport-label">游泳</text>
      </view>
    </view>
  </view>

  <!-- AI教练建议 -->
  <view class="ai-section">
    <view class="ai-header">
      <view class="ai-badge">
        <text class="ai-icon">✨</text>
        <text class="ai-text">AI教练建议</text>
      </view>
      <view class="ai-team">
        <text class="team-tag">铁三</text>
        <text class="team-tag">康复</text>
        <text class="team-tag">营养</text>
      </view>
    </view>
    
    <view class="ai-content">
      <text class="ai-title">{{aiAdvice.title}}</text>
      <text class="ai-main">{{aiAdvice.main}}</text>
      <text class="ai-details">{{aiAdvice.details}}</text>
    </view>
    
    <view class="ai-tags">
      <text class="ai-tag" wx:for="{{aiAdvice.tags}}" wx:key="index">{{item}}</text>
    </view>
    
    <view class="ai-footer">
      <text class="coach-note">{{aiAdvice.coachNote}}</text>
    </view>
  </view>

  <!-- 训练录入 -->
  <view class="input-section">
    <view class="section-header">
      <text class="section-title">训练录入</text>
    </view>
    
    <view class="input-options">
      <view class="input-card" bindtap="goToReview">
        <text class="input-icon">✏️</text>
        <text class="input-label">手动录入</text>
        <text class="input-desc">输入训练数据</text>
      </view>
      
      <view class="input-card" bindtap="uploadScreenshot">
        <text class="input-icon">📷</text>
        <text class="input-label">截图识别</text>
        <text class="input-desc">佳明/高驰/Keep</text>
      </view>
    </view>
    
    <view class="brand-hint">
      <text>即将支持：Garmin · COROS · 小米手环 · Keep</text>
    </view>
  </view>

  <!-- 本周趋势 -->
  <view class="week-section">
    <view class="section-header">
      <text class="section-title">本周趋势</text>
      <text class="week-total">本周 {{weekTotal}}km</text>
    </view>
    
    <view class="week-chart">
      <view class="chart-bars">
        <view class="bar-item" wx:for="{{weekData}}" wx:key="index">
          <view class="bar {{item.active ? 'active' : ''}}" style="height: {{item.height}}rpx"></view>
          <text class="bar-label">{{weekLabels[index]}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="action-bar">
    <button class="action-btn primary" bindtap="goToReview">
      <text class="action-icon">+</text>
      <text class="action-text">录入训练</text>
    </button>
  </view>
</view>

/* pages/race/race.wxss - Sigma风格 */
.container {
  min-height: 100vh;
  background: #0a0a0b;
  padding: 0;
  padding-bottom: 40rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
}

.set-race-btn {
  width: 80%;
  height: 96rpx;
  background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 10rpx 40rpx rgba(139, 92, 246, 0.3);
}

.race-content {
  padding: 0 40rpx;
}

.countdown-card {
  padding: 48rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(59, 130, 246, 0.15) 100%);
  border: 1px solid rgba(139, 92, 246, 0.3);
  border-radius: 32rpx;
  text-align: center;
  margin-top: 120rpx;
}

.race-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.race-type {
  font-size: 26rpx;
  color: #a78bfa;
  margin-bottom: 32rpx;
}

.countdown-number {
  font-size: 140rpx;
  font-weight: 800;
  color: #8b5cf6;
  line-height: 1;
}

.countdown-label {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.6);
}

.countdown-date {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 16rpx;
}

.card {
  margin-top: 32rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 28rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.card-value {
  font-size: 28rpx;
  color: #8b5cf6;
  font-weight: 600;
}

.progress-bar {
  height: 16rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #8b5cf6 0%, #6366f1 100%);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.plan-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.plan-item {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.plan-icon {
  font-size: 40rpx;
}

.plan-text {
  font-size: 28rpx;
  color: #fff;
}

.focus-box {
  margin-top: 20rpx;
  padding: 20rpx;
  background: rgba(139, 92, 246, 0.1);
  border-radius: 16rpx;
}

.focus-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.focus-text {
  font-size: 28rpx;
  color: #a78bfa;
  font-weight: 600;
  margin-left: 8rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  flex: 1;
  line-height: 1.5;
}

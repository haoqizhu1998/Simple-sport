/* pages/race/race.wxss - Sigma深色风格 */
.container {
  min-height: 100vh;
  background: #0a0a0b;
  padding-bottom: 40rpx;
}

/* 无赛事状态 */
.empty-state {
  padding-top: 160rpx;
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 400rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%);
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 10rpx 40rpx rgba(139, 92, 246, 0.3);
}

.btn-icon {
  font-size: 36rpx;
}

/* 赛事推荐 */
.recommend-section {
  padding: 48rpx 40rpx 0;
}

.section-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 24rpx;
}

.recommend-list {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  overflow: hidden;
}

.recommend-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.recommend-item:last-child {
  border-bottom: none;
}

.recommend-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.recommend-info {
  flex: 1;
}

.recommend-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
}

.recommend-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

.recommend-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.3);
  font-weight: 300;
}

/* 有赛事状态 */
.race-content {
  padding: 120rpx 40rpx 0;
}

/* 倒计时卡片 */
.countdown-card {
  padding: 40rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(59, 130, 246, 0.15) 100%);
  border: 1rpx solid rgba(139, 92, 246, 0.3);
  border-radius: 32rpx;
  margin-bottom: 24rpx;
}

.countdown-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.race-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 20rpx;
  background: rgba(139, 92, 246, 0.2);
  border-radius: 20rpx;
}

.race-icon {
  font-size: 32rpx;
}

.race-type {
  font-size: 24rpx;
  color: #a78bfa;
}

.countdown-days {
  font-size: 64rpx;
  font-weight: 800;
  color: #8b5cf6;
}

.countdown-main {
  text-align: center;
  margin-bottom: 32rpx;
}

.race-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.race-date {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

.countdown-footer {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 48rpx;
}

.countdown-info {
  text-align: center;
}

.info-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  display: block;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.countdown-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* 通用卡片 */
.card {
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 28rpx;
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

/* 进度卡片 */
.progress-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #8b5cf6;
}

.progress-bar {
  height: 16rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #8b5cf6 0%, #6366f1 100%);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-tags {
  display: flex;
  gap: 16rpx;
}

.progress-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.tag-icon {
  font-size: 20rpx;
}

.tag-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 训练计划卡片 */
.plan-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.plan-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.plan-item.run {
  border-color: rgba(34, 197, 94, 0.3);
  background: rgba(34, 197, 94, 0.05);
}

.plan-item.bike {
  border-color: rgba(59, 130, 246, 0.3);
  background: rgba(59, 130, 246, 0.05);
}

.plan-item.swim {
  border-color: rgba(59, 200, 240, 0.3);
  background: rgba(59, 200, 240, 0.05);
}

.plan-item.strength {
  border-color: rgba(251, 146, 60, 0.3);
  background: rgba(251, 146, 60, 0.05);
}

.plan-icon {
  font-size: 40rpx;
}

.plan-info {
  flex: 1;
}

.plan-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.plan-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.focus-box {
  padding: 20rpx;
  background: rgba(139, 92, 246, 0.1);
  border-radius: 16rpx;
}

.focus-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.focus-value {
  font-size: 28rpx;
  color: #a78bfa;
  font-weight: 600;
  margin-left: 8rpx;
}

/* 建议卡片 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tip-item {
  display: flex;
  gap: 16rpx;
}

.tip-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.tip-content {
  flex: 1;
}

.tip-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
}

.tip-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.5;
}

/* 操作按钮 */
.action-section {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 16rpx;
  margin-top: 32rpx;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

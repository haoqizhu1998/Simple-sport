/* pages/race/race.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1A1A2E 0%, #16213E 100%);
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 60rpx;
  line-height: 1.6;
}

.set-race-btn {
  width: 80%;
  background: linear-gradient(135deg, #00D9FF 0%, #007AFF 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
}

/* 卡片通用样式 */
.card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

/* 倒计时卡片 */
.countdown-card {
  background: linear-gradient(135deg, rgba(0, 217, 255, 0.2) 0%, rgba(0, 122, 255, 0.2) 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 217, 255, 0.3);
  text-align: center;
}

.countdown-header {
  margin-bottom: 30rpx;
}

.race-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.race-type {
  font-size: 26rpx;
  color: #00D9FF;
  margin-top: 8rpx;
}

.countdown-body {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.countdown-number {
  font-size: 120rpx;
  font-weight: bold;
  color: #00D9FF;
  line-height: 1;
}

.countdown-label {
  font-size: 36rpx;
  color: #fff;
}

.countdown-date {
  font-size: 28rpx;
  color: #999;
}

/* 进度卡片 */
.progress-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #00D9FF;
}

.progress-bar {
  height: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #00D9FF 0%, #007AFF 100%);
  border-radius: 10rpx;
  transition: width 0.3s;
}

.progress-info {
  display: flex;
  justify-content: space-between;
}

.info-item {
  font-size: 24rpx;
  color: #999;
}

/* 训练计划卡片 */
.plan-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.plan-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.plan-icon {
  font-size: 36rpx;
}

.plan-text {
  font-size: 28rpx;
  color: #fff;
}

.plan-focus {
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(0, 217, 255, 0.1) 0%, rgba(0, 122, 255, 0.1) 100%);
  border-radius: 16rpx;
}

.focus-label {
  font-size: 26rpx;
  color: #999;
}

.focus-text {
  font-size: 28rpx;
  color: #00D9FF;
  font-weight: bold;
  margin-left: 8rpx;
}

/* 建议卡片 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #ccc;
  flex: 1;
  line-height: 1.5;
}

/* 查看历史按钮 */
.view-history-btn {
  background: transparent;
  border: 1rpx solid #00D9FF;
  color: #00D9FF;
  border-radius: 50rpx;
  font-size: 28rpx;
}
